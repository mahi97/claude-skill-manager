# Claude Skill Manager - Environment Variables

# GitHub API token for scouting GitHub sources (optional, degrades gracefully without it)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SkillHub API key for marketplace access (optional, public endpoints work without it)
# SKILLHUB_API_KEY=sk-sh-xxxxxxxxxxxxxxxxxxxxxxxx

# API server configuration
CSM_API_HOST=127.0.0.1
CSM_API_PORT=8000

# Registry path (default: ./registry)
# CSM_REGISTRY_DIR=./registry

# Snapshots path (default: ./snapshots)
# CSM_SNAPSHOTS_DIR=./snapshots
